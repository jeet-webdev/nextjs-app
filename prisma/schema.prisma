generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  OWNER
  CUSTOMER
  ADMIN
  ADMINISTRATION
}

model User {
  id        String   @id @default(cuid())
  name      String   @default("")
  email     String   @unique
  password  String
  phone     String   @default("")
  userType  UserType @default(CUSTOMER)
  shops     Shop[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shop {
  id          String   @id @default(cuid())
  name        String
  category    String
  city        String
  slug        String @unique @default(uuid())
  rating      String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([createdAt])
}
