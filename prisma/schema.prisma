generator client {
  provider = "prisma-client-js"
    previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  name        String       @default("")
  email       String       @unique
  password    String
  phone       BigInt       @default(0)
  userType    UserType     @default(CUSTOMER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  restaurants Restaurant[]
}

model Restaurant {
  id             String           @id @default(cuid())
  name           String
  status         RestaurantStatus @default(OPEN)
  city           String
  slug           String           @unique @default(uuid())
  Address        String
  logo           String?
  content        Json?
  contactInfo    Json?
  seoTitle       String?
  seoDescription String?
  userId         String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  menuItems      MenuItem[]
  categories     Category[]
  meals          Meal[]

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tableBookings  TableBooking[]

  @@unique([userId, slug])
  @@index([createdAt])
  @@index([slug])
  @@index([userId])
  @@map("restaurants")
}

model Meal{
  id             String  @id @default(cuid())
  name           String
  isAvailable    Boolean  @default(true)
  openingTime    String?
  closingTime    String?
  description    String?
  alwaysAvailabe Boolean? @default(true) 
  
  restaurantId   String 
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories     Category[]
  menuItems      MenuItem[]                     
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt 

  @@index([restaurantId])
  @@map("meals")
}

model Category{
  id             String        @id @default(cuid())
  name           String
  isAvailable    Boolean        @default(true)
  openingTime    String?
  closingTime    String?
  description    String?
  
  restaurantId   String 
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  mealId         String
  meal           Meal           @relation(fields: [mealId], references: [id], onDelete: Cascade)
  menuItems      MenuItem[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId, mealId])
  @@map("categories")
}


model MenuItem {
  id              String     @id @default(uuid())
  name            String
  description     String?
  price           Decimal    @db.Decimal(10, 2)
  image           String?
  isAvailable     Boolean    @default(true)
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  restaurantId    String
  mealId          String
  categoryId      String
  categories      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  meal            Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  modifiers       Modifier[]

  @@index([restaurantId, mealId, categoryId])
  @@map("menu_items")
}

model Modifier {
  id          String     @id @default(uuid())
  name        String
  price       Decimal    @default(0) @db.Decimal(10, 2)
  menuContent Json?
  noOfItem    Int?        @default(1)
  inIncluded  Boolean     @default(true)
  menuItemId  String
  menuItem    MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  
  @@map("modifiers")
}

model TableBooking {
  id           String        @id @default(uuid())
  restaurantId String
  name         String
  email        String?
  phone        String?
  date         String
  time         String
  guests       Int
  message      String?
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@map("table_bookings")
}

enum UserType {
  OWNER
  CUSTOMER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum RestaurantStatus {
  OPEN
  CLOSED
}
